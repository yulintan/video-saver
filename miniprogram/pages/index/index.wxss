.container {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  text-align: center;
}

.input {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  min-height: 160rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.player {
  width: 100%;
  border-radius: 16rpx;
  background: #000;
}

.btn {
  background: #fe2c55;
  color: #fff;
  border-radius: 16rpx;
  font-size: 34rpx;
  height: 96rpx;
  line-height: 96rpx;
}

.btn[disabled] { opacity: 0.6; }

.btn-secondary {
  background: #f5f5f5;
  color: #333;
  border-radius: 16rpx;
  font-size: 30rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.progress-wrap {
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #555;
  text-align: center;
}

.status {
  text-align: center;
  font-size: 28rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.success { background: #e8f5e9; color: #2e7d32; }
.error   { background: #fdecea; color: #c62828; }
